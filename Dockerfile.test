# Dockerfile.test
FROM rust:latest

# Install sqlite and Vulkan client libraries for mock runtimes/checks
RUN apt-get update && apt-get install -y \
    sqlite3 \
    libsqlite3-dev \
    libvulkan1 \
    vulkan-tools \
    git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /koval
COPY . .

# Run cargo test on workspace in build stage
CMD ["cargo", "test", "--workspace"]
